@echo off
chcp 65001 >nul
setlocal enabledelayedexpansion

echo ========================================
echo   رفع مشروع Bayane POS الى GitHub
echo ========================================
echo.

REM ---------------------------------------------------------
REM 1) التأكد اننا داخل مجلد المشروع الصحيح
REM ---------------------------------------------------------
if not exist "artisan" (
    echo [خطأ] لم يتم العثور على ملف artisan في هذا المجلد.
    echo تأكد انك شغلت هذا الملف من داخل مجلد المشروع G:\stationery_pos
    pause
    exit /b 1
)

REM ---------------------------------------------------------
REM 2) التأكد ان .env مستبعد من Git قبل اي شيء
REM ---------------------------------------------------------
findstr /C:".env" .gitignore >nul 2>&1
if errorlevel 1 (
    echo [تحذير] ملف .env غير موجود في .gitignore!
    echo سيتم اضافته الآن تلقائياً لحمايتك من رفع بيانات حساسة.
    echo. >> .gitignore
    echo .env >> .gitignore
)

REM ---------------------------------------------------------
REM 3) تهيئة Git إذا لم يكن مهيأ من قبل
REM ---------------------------------------------------------
if not exist ".git" (
    echo [1/6] تهيئة مستودع Git جديد...
    git init
) else (
    echo [1/6] مستودع Git موجود مسبقاً، تخطي التهيئة.
)

REM ---------------------------------------------------------
REM 4) اضافة كل الملفات
REM ---------------------------------------------------------
echo [2/6] اضافة الملفات...
git add .

REM ---------------------------------------------------------
REM 5) طلب رسالة الـ commit من المستخدم
REM ---------------------------------------------------------
set "commitmsg="
set /p commitmsg="اكتب رسالة التحديث (Commit Message) او اضغط Enter للرسالة الافتراضية: "

if "!commitmsg!"=="" (
    set "commitmsg=Update Bayane POS system"
)

echo [3/6] حفظ التغييرات (commit)...
git commit -m "!commitmsg!"

REM ---------------------------------------------------------
REM 6) التأكد من وجود remote، واضافته اذا لم يكن موجوداً
REM ---------------------------------------------------------
git remote get-url origin >nul 2>&1
if errorlevel 1 (
    echo [4/6] لا يوجد remote مرتبط بعد.
    set /p repourl="الصق رابط مستودع GitHub الخاص بك (مثال: https://github.com/khichaya/stationery_pos.git): "
    git remote add origin "!repourl!"
) else (
    echo [4/6] الـ remote موجود مسبقاً، تخطي هذه الخطوة.
)

REM ---------------------------------------------------------
REM 7) تسمية الفرع الرئيسي main
REM ---------------------------------------------------------
echo [5/6] ضبط الفرع الرئيسي main...
git branch -M main

REM ---------------------------------------------------------
REM 8) الرفع الفعلي الى GitHub
REM ---------------------------------------------------------
echo [6/6] جاري الرفع الى GitHub...
echo (سيُطلب منك تسجيل الدخول: Username + Personal Access Token بدل كلمة السر)
git push -u origin main

echo.
echo ========================================
echo   انتهت العملية. تحقق من النتيجة اعلاه.
echo ========================================
pause